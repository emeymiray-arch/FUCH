# Скопируйте в .env и заполните

PORT=3001
API_SECRET=ваш-секретный-ключ-для-приложения

# ─── Т-Банк (Т-Бизнес) ───
# ЛК Т-Бизнес → Сервисы → Интеграции → T-API → Выпустить токен
# Документация: https://developer.tinkoff.ru/docs/api/get-api-v-1-statement
TINKOFF_TOKEN=
TINKOFF_ACCOUNT_NUMBER=

# ─── Сбер (Sber API) ───
# developers.sber.ru → Личный кабинет → Client ID / Secret
# Документация: https://developers.sber.ru/docs/ru/sber-api/specifications/statement/transactions
SBER_ACCESS_TOKEN=
SBER_ACCOUNT_NUMBER=

# ─── Ozon Банк ───
# Публичного API пока нет — укажите URL, если банк выдаст доступ
OZON_BANK_API_URL=
OZON_BANK_TOKEN=
OZON_ACCOUNT_NUMBER=
